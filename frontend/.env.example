# Base URL of the CrownWager API (legacy localStorage/Bearer mode). In docker-compose this is
# the host-mapped backend. Ignored when NEXT_PUBLIC_AUTH_COOKIE_ENABLED=true (calls same-origin /api).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Cookie-auth mode: the browser calls same-origin /api (proxied to API_PROXY_TARGET) and the JWT
# lives in HttpOnly cookies. Set BOTH this and the backend AUTH_COOKIE_ENABLED=true to switch.
NEXT_PUBLIC_AUTH_COOKIE_ENABLED=
# Backend ORIGIN that /api/* is proxied to in cookie mode (the Django app serves under /api).
API_PROXY_TARGET=http://localhost:8000

# Sentry DSN for error tracking. Leave empty to fully disable Sentry (no-op).
# The same DSN is used client-side (browser) and falls back for the server runtime.
NEXT_PUBLIC_SENTRY_DSN=
