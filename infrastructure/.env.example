# ─── Copy to infrastructure/.env and fill in. NEVER commit the real .env. ───
# All secrets here are placeholders. Rotate anything that ever leaked.

# Django
DJANGO_ENV=dev
DJANGO_SETTINGS_MODULE=config_project.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (docker-compose provides Postgres; local dev defaults to SQLite if unset)
DATABASE_URL=postgresql://oddsaway:oddsaway@db:5432/oddsaway

# Cache / broker
CACHE_BACKEND=redis
REDIS_URL=redis://redis:6379/0

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# The Odds API (https://the-odds-api.com). Leave blank to run in demo mode.
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# AI prediction service
AI_SERVICE_URL=http://ai:8001

# Shared secret for the scheduled-refresh endpoint (/api/internal/refresh/).
# Leave blank to disable it; set a long random value in prod + the matching GitHub secret.
REFRESH_TOKEN=

# Email (optional; console backend used in dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── OddsBot assistant (optional) ───────────────────────────────────────────
# OddsBot works with NO key (offline rule-based summary). To enable a real LLM, pick ONE:
#
# Option A — Anthropic (Claude):
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Option B — any OpenAI-compatible provider via LLM_* (free options below):
#   Groq (free, fast):    LLM_BASE_URL=https://api.groq.com/openai/v1
#                         LLM_MODEL=llama-3.3-70b-versatile
#   Google Gemini (free): LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#                         LLM_MODEL=gemini-2.5-flash   (2.0-flash may show a 0 free-tier quota)
#   OpenRouter:           LLM_BASE_URL=https://openrouter.ai/api/v1
#                         LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Ollama (local, no key, set LLM_API_KEY=ollama):
#                         LLM_BASE_URL=http://host.docker.internal:11434/v1
#                         LLM_MODEL=llama3.2
ANTHROPIC_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Frontend (Next.js) — public API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
