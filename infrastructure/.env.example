# ─── Copy to infrastructure/.env and fill in. NEVER commit the real .env. ───
# All secrets here are placeholders. Rotate anything that ever leaked.

# Django
DJANGO_ENV=dev
DJANGO_SETTINGS_MODULE=config_project.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (docker-compose provides Postgres; local dev defaults to SQLite if unset)
DATABASE_URL=postgresql://crownwager:crownwager@db:5432/crownwager

# Cache / broker
CACHE_BACKEND=redis
REDIS_URL=redis://redis:6379/0

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# The Odds API (https://the-odds-api.com). Leave blank to run in demo mode.
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# AI prediction service
AI_SERVICE_URL=http://ai:8001

# Shared secret for the scheduled-refresh endpoint (/api/internal/refresh/).
# Leave blank to disable it; set a long random value in prod + the matching GitHub secret.
REFRESH_TOKEN=

# Email — password-reset delivery (optional; the console backend prints the link in dev).
# To actually SEND email in prod, use a free Gmail App Password (works for anyone with a Gmail):
#   1. Turn on 2-Step Verification for the Google account.
#   2. Google Account -> Security -> App passwords -> generate one (16 chars).
#   3. Set EMAIL_HOST_USER to that Gmail address + EMAIL_HOST_PASSWORD to the app password.
# Left blank, forgot-password still works end-to-end but no email is delivered (the link is logged).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
# Base URL of the deployed frontend — used to build password-reset links. Set to your Vercel URL in prod.
FRONTEND_URL=http://localhost:3000

# ── CrownBot assistant (optional) ───────────────────────────────────────────
# CrownBot works with NO key (offline rule-based summary). To enable a real LLM, pick ONE:
#
# Option A — Anthropic (Claude):
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Option B — any OpenAI-compatible provider via LLM_* (free options below):
#   Groq (free, fast):    LLM_BASE_URL=https://api.groq.com/openai/v1
#                         LLM_MODEL=llama-3.3-70b-versatile
#   Google Gemini (free): LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#                         LLM_MODEL=gemini-2.5-flash   (2.0-flash may show a 0 free-tier quota)
#   OpenRouter:           LLM_BASE_URL=https://openrouter.ai/api/v1
#                         LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Ollama (local, no key, set LLM_API_KEY=ollama):
#                         LLM_BASE_URL=http://host.docker.internal:11434/v1
#                         LLM_MODEL=llama3.2
ANTHROPIC_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Frontend (Next.js) — public API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
